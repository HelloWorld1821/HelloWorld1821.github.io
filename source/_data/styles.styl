.sidebar-tag-cloud {
  margin-top: 24px;
  color: var(--text-color);

  .widget-title {
    color: var(--text-color);
    font-size: 1.15em;
    margin: 0 0 12px;
    text-align: center;
  }

  .sidebar-tag-cloud-tags {
    align-items: center;
    align-content: center;
    background: rgba(127, 127, 127, .06);
    border: 1px solid rgba(127, 127, 127, .18);
    border-radius: 48% 52% 46% 54% / 40% 46% 54% 60%;
    box-shadow: inset 0 0 28px rgba(127, 127, 127, .08);
    display: grid;
    grid-auto-rows: minmax(20px, auto);
    grid-template-columns: repeat(8, minmax(0, 1fr));
    justify-items: center;
    line-height: 1.35;
    margin: 0 auto;
    max-height: 330px;
    min-height: 205px;
    overflow-y: auto;
    padding: 18px 8px 20px;
    position: relative;

    a {
      --tag-color: var(--link-color);
      --tag-rotate: 0deg;
      color: var(--tag-color) !important;
      display: inline-block;
      font-family: "Microsoft YaHei", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
      font-weight: 700;
      letter-spacing: 0;
      max-width: 100%;
      padding: 1px 2px;
      text-shadow: 0 1px 2px rgba(0, 0, 0, .08);
      text-decoration: none;
      transform: rotate(var(--tag-rotate));
      transition: color .2s ease, opacity .2s ease, transform .2s ease;
      word-break: break-word;
      z-index: 1;

      &:hover {
        color: var(--link-hover-color) !important;
        opacity: .9;
        transform: translateY(-1px) rotate(var(--tag-rotate));
      }
    }
  }

  .sidebar-tag-cloud-tags-sparse {
    grid-auto-rows: minmax(28px, auto);
    min-height: 190px;
    padding: 22px 10px 24px;
  }

  .sidebar-tag-cloud-tags a:nth-child(24n + 1) {
    grid-column: 3 / span 2;
    grid-row: auto / span 1;
    --tag-rotate: -7deg;
  }

  .sidebar-tag-cloud-tags a:nth-child(24n + 2) {
    grid-column: 5 / span 2;
    grid-row: auto / span 1;
    --tag-rotate: 5deg;
  }

  .sidebar-tag-cloud-tags a:nth-child(24n + 3) {
    grid-column: 2 / span 3;
    grid-row: auto / span 1;
    --tag-rotate: 3deg;
  }

  .sidebar-tag-cloud-tags a:nth-child(24n + 4) {
