.sidebar-tag-cloud {
  .sidebar-tag-cloud-tags {
    aspect-ratio: 1.45;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
    display: block;
    height: auto;
    max-height: none;
    min-height: 165px;
    overflow: hidden;
    padding: 0;
    position: relative;
    user-select: none;
  }

  .sidebar-tag-cloud-word {
    --tag-color: var(--link-color);
    --tag-rotate: 0deg;
    --tag-x: 50%;
    --tag-y: 50%;
    border: 0;
    color: var(--tag-color) !important;
    display: block;
    font-family: "Microsoft YaHei", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
    font-size: clamp(12px, 1.45vw, 17px);
    font-weight: 700;
    left: var(--tag-x);
    letter-spacing: 0;
    line-height: 1;
    opacity: .78;
    pointer-events: none;
    position: absolute;
    text-decoration: none;
    text-shadow: 0 1px 2px rgba(0, 0, 0, .08);
    top: var(--tag-y);
    transform: translate(-50%, -50%) rotate(var(--tag-rotate));
    white-space: nowrap;
  }

  .sidebar-tag-cloud-word-fill {
    font-size: clamp(12px, 1.25vw, 16px);
  }

  .sidebar-tag-cloud-word-major {
    font-size: clamp(16px, 2.35vw, 28px);
    opacity: .95;
